<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gerador de Triagem Orlando - Orange Viagens</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 20px;
            min-height: 100vh;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            background: white;
            border-radius: 10px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            overflow: hidden;
        }

        header {
            background: linear-gradient(135deg, #FF8C00 0%, #FFB347 100%);
            color: white;
            padding: 40px 20px;
            text-align: center;
        }

        header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }

        header p {
            font-size: 1.1em;
            opacity: 0.95;
        }

        .content {
            padding: 40px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
        }

        .section {
            display: flex;
            flex-direction: column;
        }

        .section h2 {
            background: #f5f5f5;
            color: #FF8C00;
            padding: 15px;
            border-left: 5px solid #FF8C00;
            margin-bottom: 20px;
            font-size: 1.3em;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            color: #333;
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 0.95em;
        }

        .radio-group {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }

        .radio-group label {
            display: flex;
            align-items: center;
            margin-bottom: 0;
            cursor: pointer;
            font-weight: 500;
        }

        .radio-group input[type="radio"] {
            margin-right: 8px;
            cursor: pointer;
            width: 18px;
            height: 18px;
        }

        textarea {
            width: 100%;
            padding: 15px;
            border: 2px solid #ddd;
            border-radius: 8px;
            font-family: 'Courier New', monospace;
            font-size: 0.95em;
            line-height: 1.6;
            resize: vertical;
            min-height: 400px;
            transition: border-color 0.3s ease;
        }

        textarea:focus {
            outline: none;
            border-color: #FF8C00;
            box-shadow: 0 0 10px rgba(255, 140, 0, 0.2);
        }

        input[type="text"] {
            width: 100%;
            padding: 12px;
            border: 2px solid #ddd;
            border-radius: 8px;
            font-size: 0.95em;
            transition: border-color 0.3s ease;
        }

        input[type="text"]:focus {
            outline: none;
            border-color: #FF8C00;
        }

        .button-group {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }

        button {
            flex: 1;
            padding: 15px 20px;
            border: none;
            border-radius: 8px;
            font-size: 1em;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-gerar {
            background: linear-gradient(135deg, #FF8C00 0%, #FFB347 100%);
            color: white;
        }

        .btn-gerar:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 140, 0, 0.4);
        }

        .btn-gerar:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .btn-copiar {
            background: #4CAF50;
            color: white;
        }

        .btn-copiar:hover {
            background: #45a049;
        }

        .btn-limpar {
            background: #f44336;
            color: white;
        }

        .btn-limpar:hover {
            background: #da190b;
        }

        .btn-baixar {
            background: #2196F3;
            color: white;
        }

        .btn-baixar:hover {
            background: #0b7dda;
        }

        .triagem-output {
            background: #f9f9f9;
            border: 2px solid #FF8C00;
            border-radius: 8px;
            padding: 20px;
            font-family: 'Courier New', monospace;
            font-size: 0.95em;
            line-height: 1.6;
            white-space: pre-wrap;
            word-wrap: break-word;
            max-height: 500px;
            overflow-y: auto;
            color: #333;
        }

        .triagem-output:empty::before {
            content: 'A triagem aparecerá aqui...';
            color: #999;
        }

        .status-message {
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            display: none;
            font-weight: 500;
        }

        .status-message.success {
            background: #E8F5E9;
            color: #2E7D32;
            border: 1px solid #4CAF50;
            display: block;
        }

        .status-message.error {
            background: #FFEBEE;
            color: #C62828;
            border: 1px solid #f44336;
            display: block;
        }

        .status-message.info {
            background: #E3F2FD;
            color: #1565C0;
            border: 1px solid #2196F3;
            display: block;
        }

        footer {
            background: #333;
            color: white;
            text-align: center;
            padding: 20px;
            margin-top: 40px;
        }

        .instructions {
            background: #FFF8DC;
            border-left: 5px solid #FF8C00;
            padding: 15px;
            border-radius: 5px;
            margin-bottom: 20px;
            font-size: 0.9em;
            line-height: 1.6;
            color: #333;
        }

        .instructions strong {
            color: #FF8C00;
        }

        .spinner {
            display: none;
            text-align: center;
            padding: 20px;
            color: #FF8C00;
            font-weight: bold;
        }

        .spinner.active {
            display: block;
        }

        @media (max-width: 768px) {
            .content {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            header h1 {
                font-size: 1.8em;
            }

            textarea {
                min-height: 300px;
            }

            .button-group {
                flex-direction: column;
            }

            .radio-group {
                flex-direction: column;
                gap: 10px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>🍊 Gerador de Triagem Orlando</h1>
            <p>Orange Viagens - Sistema Inteligente com IA</p>
        </header>

        <div class="content">
            <!-- COLUNA ESQUERDA: INPUT -->
            <div class="section">
                <h2>📥 Cole a Conversa com o Cliente</h2>
                
                <div class="instructions">
                    <strong>Como usar:</strong><br>
                    1. Escolha o tipo de triagem<br>
                    2. Preencha o nome do cliente<br>
                    3. Cole a conversa completa<br>
                    4. Clique em "Gerar Triagem"
                </div>

                <div class="form-group">
                    <label>📋 Tipo de Triagem</label>
                    <div class="radio-group">
                        <label>
                            <input type="radio" name="tipoTriagem" value="completa" checked>
                            Completa (Orlando)
                        </label>
                        <label>
                            <input type="radio" name="tipoTriagem" value="ingressos">
                            Apenas Ingressos
                        </label>
                    </div>
                </div>

                <div class="form-group">
                    <label for="nomeCliente">👤 Nome do Cliente (obrigatório)</label>
                    <input type="text" id="nomeCliente" placeholder="Ex: João Silva">
                </div>

                <div class="form-group">
                    <label for="conversa">💬 Cole a conversa aqui</label>
                    <textarea id="conversa" placeholder="Cole aqui toda a conversa com o cliente, incluindo as perguntas da consultora..."></textarea>
                </div>

                <div class="button-group">
                    <button class="btn-gerar" id="btnGerar" onclick="gerarTriagem()">🚀 Gerar Triagem</button>
                    <button class="btn-limpar" onclick="limparFormulario()">🗑️ Limpar</button>
                </div>
            </div>

            <!-- COLUNA DIREITA: OUTPUT -->
            <div class="section">
                <h2>📋 Triagem Gerada</h2>
                
                <div id="statusMessage" class="status-message"></div>
                <div id="spinner" class="spinner">⏳ Analisando conversa com IA Claude...</div>

                <div class="triagem-output" id="triagem"></div>

                <div class="button-group" style="margin-top: 20px;">
                    <button class="btn-copiar" onclick="copiarTriagem()">📋 Copiar</button>
                    <button class="btn-baixar" onclick="baixarTriagem()">⬇️ Baixar</button>
                </div>
            </div>
        </div>

        <footer>
            <p>&copy; 2024 Orange Viagens | 🍊 Roteiro em Orlando</p>
            <p style="margin-top: 10px; font-size: 0.9em;">Sistema Inteligente de Triagem com Claude AI</p>
        </footer>
    </div>

    <script>
        // Detectar URL do backend (desenvolvimento local ou produção)
        const BACKEND_URL = window.location.hostname === 'localhost' 
            ? 'http://localhost:3001'
            : 'https://seu-backend-vercel.vercel.app'; // Será substituído após deploy

        window.addEventListener('load', () => {
            document.getElementById('nomeCliente').focus();
        });

        function mostrarMensagem(mensagem, tipo) {
            const statusDiv = document.getElementById('statusMessage');
            statusDiv.textContent = mensagem;
            statusDiv.className = `status-message ${tipo}`;
            
            if (tipo !== 'info') {
                setTimeout(() => {
                    statusDiv.className = 'status-message';
                }, 5000);
            }
        }

        function mostrarSpinner(ativo) {
            const spinner = document.getElementById('spinner');
            const btnGerar = document.getElementById('btnGerar');
            if (ativo) {
                spinner.classList.add('active');
                btnGerar.disabled = true;
            } else {
                spinner.classList.remove('active');
                btnGerar.disabled = false;
            }
        }

        async function gerarTriagem() {
            const nomeCliente = document.getElementById('nomeCliente').value.trim();
            const conversa = document.getElementById('conversa').value.trim();
            const tipoTriagem = document.querySelector('input[name="tipoTriagem"]:checked').value;

            if (!nomeCliente) {
                mostrarMensagem('❌ Por favor, preencha o nome do cliente', 'error');
                return;
            }

            if (!conversa) {
                mostrarMensagem('❌ Por favor, cole a conversa com o cliente', 'error');
                return;
            }

            mostrarSpinner(true);
            mostrarMensagem('⏳ Analisando conversa com IA...', 'info');

            try {
                const response = await fetch(`${BACKEND_URL}/api/triagem`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        nomeCliente,
                        conversa,
                        tipoTriagem
                    })
                });

                if (!response.ok) {
                    const erro = await response.json();
                    throw new Error(erro.message || 'Erro ao processar a triagem');
                }

                const data = await response.json();
                document.getElementById('triagem').textContent = data.triagem;
                mostrarSpinner(false);
                mostrarMensagem('✅ Triagem gerada com sucesso!', 'success');
            } catch (erro) {
                console.error('Erro:', erro);
                mostrarSpinner(false);
                mostrarMensagem('❌ Erro: ' + erro.message, 'error');
            }
        }

        function copiarTriagem() {
            const triagem = document.getElementById('triagem').textContent;
            
            if (!triagem || triagem.includes('aparecerá aqui')) {
                mostrarMensagem('❌ Nenhuma triagem para copiar', 'error');
                return;
            }

            navigator.clipboard.writeText(triagem).then(() => {
                mostrarMensagem('✅ Triagem copiada para clipboard!', 'success');
            }).catch(() => {
                mostrarMensagem('❌ Erro ao copiar', 'error');
            });
        }

        function baixarTriagem() {
            const nomeCliente = document.getElementById('nomeCliente').value.trim();
            const triagem = document.getElementById('triagem').textContent;

            if (!triagem || triagem.includes('aparecerá aqui')) {
                mostrarMensagem('❌ Nenhuma triagem para baixar', 'error');
                return;
            }

            const elemento = document.createElement('a');
            elemento.setAttribute('href', 'data:text/plain;charset=utf-8,' + encodeURIComponent(triagem));
            elemento.setAttribute('download', `TRIAGEM_${nomeCliente.toUpperCase().replace(/\s+/g, '_')}.txt`);
            elemento.style.display = 'none';
            document.body.appendChild(elemento);
            elemento.click();
            document.body.removeChild(elemento);

            mostrarMensagem('✅ Arquivo baixado com sucesso!', 'success');
        }

        function limparFormulario() {
            document.getElementById('nomeCliente').value = '';
            document.getElementById('conversa').value = '';
            document.getElementById('triagem').textContent = '';
            document.getElementById('statusMessage').className = 'status-message';
            document.getElementById('nomeCliente').focus();
        }
    </script>
</body>
</html>
